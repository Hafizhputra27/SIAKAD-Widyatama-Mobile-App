<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@color/background">

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <!-- Background image with purple overlay -->
        <ImageView
            android:layout_width="match_parent"
            android:layout_height="320dp"
            android:scaleType="centerCrop"
            android:src="@drawable/mainhall"
            android:contentDescription="@string/university_name" />

        <View
            android:layout_width="match_parent"
            android:layout_height="320dp"
            android:background="@drawable/bg_login_gradient" />

        <!-- Bottom white card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="240dp"
            android:background="@drawable/bg_top_rounded"
            android:orientation="vertical"
            android:paddingHorizontal="24dp"
            android:paddingTop="32dp"
            android:paddingBottom="24dp">

            <!-- Logos -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginBottom="24dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageView
                    android:layout_width="80dp"
                    android:layout_height="64dp"
                    android:adjustViewBounds="true"
                    android:scaleType="fitCenter"
                    android:src="@drawable/logo_widyatama"
                    android:contentDescription="Logo Widyatama" />

                <View
                    android:layout_width="1dp"
                    android:layout_height="40dp"
                    android:layout_marginHorizontal="16dp"
                    android:background="@color/divider" />

                <ImageView
                    android:layout_width="80dp"
                    android:layout_height="64dp"
                    android:src="@drawable/logo_diktisaintek"
                    android:contentDescription="Logo Diktisaintek" />
            </LinearLayout>

            <!-- Title -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginBottom="4dp"
                android:text="@string/sign_in_title"
                android:textAppearance="@style/TextAppearance.MyApplication.HeadlineMedium"
                android:textColor="@color/primary" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginBottom="28dp"
                android:text="Sistem Informasi Akademik"
                android:textAppearance="@style/TextAppearance.MyApplication.BodyMedium"
                android:textColor="@color/text_secondary" />

            <!-- NPM Input -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilStudentId"
                style="@style/Widget.MyApplication.TextInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:hint="@string/student_id_hint"
                app:startIconDrawable="@drawable/ic_person"
                app:startIconTint="@color/primary">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etStudentId"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="text"
                    android:textAppearance="@style/TextAppearance.MyApplication.BodyLarge" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Password Input -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilPassword"
                style="@style/Widget.MyApplication.TextInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:hint="@string/password_hint"
                app:endIconMode="password_toggle"
                app:endIconTint="@color/primary"
                app:startIconDrawable="@drawable/ic_lock"
                app:startIconTint="@color/primary">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etPassword"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textPassword"
                    android:textAppearance="@style/TextAppearance.MyApplication.BodyLarge" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Remember me & Forgot password -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/switchRememberMe"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/remember_me"
                    android:textAppearance="@style/TextAppearance.MyApplication.BodyMedium"
                    android:textColor="@color/text_secondary"
                    app:thumbTint="@color/primary"
                    app:trackTint="@color/primary_light" />

                <View
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:layout_weight="1" />

                <TextView
                    android:id="@+id/tvForgotPassword"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/forgot_password"
                    android:textAppearance="@style/TextAppearance.MyApplication.LabelLarge"
                    android:textColor="@color/primary" />
            </LinearLayout>

            <!-- Login Button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnLogin"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginBottom="16dp"
                android:text="@string/login_button"
                android:textAppearance="@style/TextAppearance.MyApplication.Button"
                android:textColor="@color/white"
                app:backgroundTint="@color/primary"
                app:cornerRadius="12dp"
                app:elevation="4dp" />

            <!-- Info text -->
            <TextView
                android:id="@+id/tvInfoAkun"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginBottom="24dp"
                android:gravity="center"
                android:text="Belum punya akun? Hubungi admin akademik"
                android:textAppearance="@style/TextAppearance.MyApplication.LabelMedium"
                android:textColor="@color/text_hint" />

            <!-- Copyright -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="@string/copyright"
                android:textAppearance="@style/TextAppearance.MyApplication.LabelMedium"
                android:textColor="@color/text_hint" />

        </LinearLayout>
    </FrameLayout>
</ScrollView>
