<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <rotate
            android:fromDegrees="180"
            android:pivotX="0"
            android:pivotY="0"
            android:toDegrees="180">
            <shape android:shape="rectangle">
                <solid android:color="@color/white" />
                <size android:width="4dp" android:height="30dp" />
            </shape>
        </rotate>
    </item>
    <item>
        <rotate
            android:fromDegrees="0"
            android:pivotX="0"
            android:pivotY="0"
            android:toDegrees="0">
            <shape android:shape="rectangle">
                <solid android:color="@color/white" />
                <size android:width="30dp" android:height="4dp" />
            </shape>
        </rotate>
    </item>
</layer-list>